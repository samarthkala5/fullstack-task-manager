{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node", "express"],
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["prisma.config.ts"]
}